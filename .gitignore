# =============================================================
# TenniTech-RTAB-SLAM — .gitignore
# =============================================================
# Git 不会跟踪此文件中列出的路径模式。
# 原则:任何"生成产物"、"大文件"、"机器/用户专属"都不入库。
# =============================================================

# --- SLAM 数据产物(GB 量级,绝对不入库)----------------------
bags/
maps/
logs/
*.db
*.db3
*.mcap
*.bag
*.pcd
*.ply

# --- ROS 2 构建产物 ------------------------------------------
build/
install/
log/
.colcon/

# --- Python ---------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# --- C/C++(以防以后加 C++ 代码)-----------------------------
*.o
*.a
*.so
*.dylib

# --- 编辑器 / IDE --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- 操作系统 ------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- 本地 / 敏感配置 ------------------------------------------
.env
.env.local
*.local
*.key
*.pem
secrets.yaml
